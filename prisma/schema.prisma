generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ROLE {
  STUDENT
  CARETAKER
  SUPERVISOR
}

enum PRIORITY {
  HIGH
  MEDIUM
  LOW
}

enum STATUS {
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum RESOLUTION_STATUS {
  PENDING
  APPROVED
  REJECTED
  DISCARDED
}

enum COMPLAINT_AUDIT {
  ASSIGNED
  UNASSIGNED
  STATUS_CHANGED
  ESCALATED
  RESOLUTION_SUBMITTED
  RESOLUTION_APPROVED
  RESOLUTION_REJECTED
  REOPENED
}

model User {
  id                  String           @id @default(cuid())
  name                String
  email               String           @unique
  password            String
  role                ROLE             @default(STUDENT)
  points              Int              @default(0)
  complaints          Complaint[]      @relation("UserComplaints")
  assignedComplaints  Complaint[]      @relation("AssignedComplaints")
  resolutions         Resolution[]
  complaintActivities ComplaintAudit[]
  comments            Comment[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  upvotes             Upvotes[]
}

model Complaint {
  id           String           @id @default(cuid())
  title        String
  description  String?
  media        String[]         @default([])
  priority     PRIORITY         @default(LOW)
  status       STATUS           @default(PENDING)
  upvotesCount Int              @default(0)
  userId       String
  user         User             @relation("UserComplaints", fields: [userId], references: [id])
  assignedToId String?
  assignedTo   User?            @relation("AssignedComplaints", fields: [assignedToId], references: [id])
  deadline     DateTime?
  isEscalated  Boolean          @default(false)
  isEdited     Boolean          @default(false)
  upvotes      Upvotes[]
  commentList  Comment[]
  resolutions  Resolution[]
  activities   ComplaintAudit[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([userId, assignedToId])
}

model Comment {
  id          String    @id @default(cuid())
  description String
  complaintId String
  complaint   Complaint @relation(fields: [complaintId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, complaintId])
}

model Resolution {
  id              String            @id @default(cuid())
  number          Int
  description     String?
  media           String[]          @default([])
  complaintId     String
  complaint       Complaint         @relation(fields: [complaintId], references: [id])
  caretakerId     String
  caretaker       User              @relation(fields: [caretakerId], references: [id])
  status          RESOLUTION_STATUS @default(PENDING)
  rejectionReason String?
  rejectedAt      DateTime?
  createdAt       DateTime          @default(now())

  @@index([complaintId, caretakerId])
}

model Upvotes {
  id          String    @id @default(cuid())
  userId      String
  complaintId String
  user        User      @relation(fields: [userId], references: [id])
  complaint   Complaint @relation(fields: [complaintId], references: [id])

  @@unique([userId, complaintId])
}

model ComplaintAudit {
  id               String          @id @default(cuid())
  type             COMPLAINT_AUDIT
  message          String
  complaintId      String
  complaint        Complaint       @relation(fields: [complaintId], references: [id])
  actorId          String
  actor            User            @relation(fields: [actorId], references: [id])
  resolutionNumber Int?
  createdAt        DateTime        @default(now())
}
